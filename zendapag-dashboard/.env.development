# Dev do dashboard da Zend (craco start)
# Porta dedicada para NÃO colidir com o One A One (Next.js, porta 3000)
PORT=3100
BROWSER=none

# baseURL do axios: relativo, para o proxy (package.json -> http://localhost:8093)
# encaminhar para o backend Java na 8093. Sem isso, em dev o baseURL fica
# undefined e as chamadas saem sem o prefixo /api/v1.
REACT_APP_API_URL=/api/v1
REACT_APP_ENVIRONMENT=development
REACT_APP_ENABLE_DEBUG=true
