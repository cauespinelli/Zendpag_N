<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- Suppress false positives for Spring Boot dependencies -->
    <suppress>
        <notes><![CDATA[
        Spring Boot auto-configuration does not expose vulnerable endpoints in production
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/.*@.*$</packageUrl>
        <cve>CVE-2021-22060</cve>
    </suppress>

    <!-- Example suppression for testing dependencies -->
    <suppress>
        <notes><![CDATA[
        Test dependencies are not included in production builds
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/junit/junit@.*$</packageUrl>
        <cve>CVE-2020-15250</cve>
    </suppress>

    <!-- Suppress low-risk vulnerabilities in development dependencies -->
    <suppress until="2025-12-31">
        <notes><![CDATA[
        Development-only dependency with low risk - to be reviewed by end of 2025
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.h2database/h2@.*$</packageUrl>
        <cvssBelow>7.0</cvssBelow>
    </suppress>

</suppressions>