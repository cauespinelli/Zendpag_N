# Zendapag - Production Environment Variables
# Copy this file to .env.production and fill in the values

# Database Configuration
DB_USERNAME=reservasegura_user
DB_PASSWORD=Voa2025Live!

# Redis Configuration
REDIS_PASSWORD=zendapag123

# JWT Configuration
JWT_SECRET=zendapag-super-secret-key-change-in-production-min-256-bits-long
JWT_EXPIRATION=86400000

# Withdrawal Configuration
APP_WITHDRAWAL_MAX_AMOUNT=50000.00
APP_WITHDRAWAL_MIN_AMOUNT=0.01
APP_WITHDRAWAL_DAILY_LIMIT=100000.00
APP_WITHDRAWAL_FEE_PERCENTAGE=0.00
APP_WITHDRAWAL_FIXED_FEE=0.00
APP_WITHDRAWAL_MAX_PENDING=5

# PIX Provider Configuration (example)
PIX_PROVIDER_URL=https://api.pix-provider.com
PIX_PROVIDER_API_KEY=your-pix-provider-api-key
PIX_PROVIDER_CLIENT_ID=your-client-id
PIX_PROVIDER_CLIENT_SECRET=your-client-secret

# Monitoring (optional)
